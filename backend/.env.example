# ============================================================
# RainFog Detection System - 環境變數範本
# 使用方式：cp .env.example .env，再依本機環境修改 .env
# 系統環境變數優先級高於 .env（支援 CI / Docker 覆蓋）
# ============================================================

# ─────────────────────────────────────────────────────────────
# Django 後端
# ─────────────────────────────────────────────────────────────

# 生產環境請替換為隨機長字串（python -c "import secrets; print(secrets.token_hex(50))"）
DJANGO_SECRET_KEY=replace-me-with-a-secure-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL 資料庫
MYSQL_DATABASE=rainfog
MYSQL_USER=rainfog
MYSQL_PASSWORD=rainfog123
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# API 分頁大小（預設 20）
API_PAGE_SIZE=20

# ─────────────────────────────────────────────────────────────
# FastAPI 推理服務（所有欄位由 pydantic-settings 以 INFERENCE_ 前綴讀取）
# ─────────────────────────────────────────────────────────────

# Django 端呼叫推理服務的 base URL
INFERENCE_BASE_URL=http://127.0.0.1:9000
# HTTP 請求逾時秒數
INFERENCE_TIMEOUT=30
# Django 側 Mock 開關（true = 推理服務不可達時自動 fallback，不中斷主流程）
INFERENCE_USE_MOCK=True

# 推理引擎模式
#   mock     ← 開發 / CI，回傳固定測試資料，不需模型檔
#   yolov13  ← 啟用真實本地推理（需先完成下方 YOLOv13 設定）
INFERENCE_MODEL_MODE=mock

# YOLOv13 原始碼根目錄（從 https://github.com/iMoonLab/yolov13 clone）
# macOS / Linux：
INFERENCE_YOLOV13_ROOT=../yolov13-main
# Windows 範例（取消下行，並刪除上行）：
# INFERENCE_YOLOV13_ROOT=C:\projects\yolov13-main

# 模型權重目錄（將 .pt 檔放入此目錄，詳見 data/models/README.md）
INFERENCE_MODELS_ROOT=../data/models

# 預設載入的模型規格
#   yolov13n.pt ← nano，最快；yolov13s / l / x 精度依次提升
INFERENCE_YOLOV13_MODEL_FILE=yolov13n.pt

# 識別結果圖輸出目錄
INFERENCE_RESULTS_ROOT=../data/results

# 資料集根目錄（訓練資料的上層目錄，詳見 data/datasets/README.md）
INFERENCE_DATASETS_ROOT=../data/datasets

# 日誌等級：DEBUG | INFO | WARNING | ERROR
INFERENCE_LOG_LEVEL=INFO
