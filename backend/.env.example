# ============================================================
# RainFog Detection System - 環境變數範本
# 使用方式：cp .env.example .env，再依本機環境修改 .env
# 系統環境變數優先級高於 .env（支援 CI / Docker 覆蓋）
# ============================================================

# ─────────────────────────────────────────────────────────────
# Django 後端
# ─────────────────────────────────────────────────────────────

# 生產環境請替換為隨機長字串（python -c "import secrets; print(secrets.token_hex(50))"）
DJANGO_SECRET_KEY=replace-me-with-a-secure-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL 資料庫
MYSQL_DATABASE=rainfog
MYSQL_USER=rainfog
MYSQL_PASSWORD=rainfog123
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# API 分頁大小（預設 20）
API_PAGE_SIZE=20

# ─────────────────────────────────────────────────────────────
# FastAPI 推理服務（所有欄位由 pydantic-settings 以 INFERENCE_ 前綴讀取）
# ─────────────────────────────────────────────────────────────

# Django 端呼叫推理服務的 base URL
INFERENCE_BASE_URL=http://127.0.0.1:9000
# HTTP 請求逾時秒數
INFERENCE_TIMEOUT=30
# Django 側 Mock 開關（true = 推理服務不可達時自動 fallback，不中斷主流程）
INFERENCE_USE_MOCK=True

# 默認識別模式
#   scene_default ← 未顯式指定模式時，自動套用場景模式
#   image         ← 保留原有圖片識別流程，可由前端或 API 顯式指定
DETECTION_DEFAULT_RECOGNITION_MODE=scene_default
DETECTION_DEFAULT_SCENE=rain_fog
DETECTION_SCENE_CONFIDENCE_THRESHOLD=0.35
DETECTION_SCENE_IOU_THRESHOLD=0.5
DETECTION_SCENE_PREPROCESS_MODE=auto
DETECTION_SCENE_PREPROCESS_PROFILE=scene_default
DETECTION_SCENE_PREPROCESS_ENABLE_GAMMA=True
DETECTION_SCENE_MODEL_PROFILE=scene_default
DETECTION_SCENE_IMAGE_SIZE=960
DETECTION_SCENE_ENABLE_AUGMENT=True

# 推理引擎模式
#   mock     ← 開發 / CI，回傳固定測試資料，不需模型檔
#   yolov13  ← 啟用真實本地推理（需先完成下方 YOLOv13 設定）
INFERENCE_MODEL_MODE=mock

# YOLOv13 原始碼根目錄（從 https://github.com/iMoonLab/yolov13 clone）
# macOS / Linux：
INFERENCE_YOLOV13_ROOT=../yolov13-main
# Windows 範例（取消下行，並刪除上行）：
# INFERENCE_YOLOV13_ROOT=C:\projects\yolov13-main

# 模型權重目錄（將 .pt 檔放入此目錄，詳見 data/models/README.md）
INFERENCE_MODELS_ROOT=../data/models

# 預設載入的模型規格
#   yolov13n.pt ← nano，最快；yolov13s / l / x 精度依次提升
INFERENCE_YOLOV13_MODEL_FILE=yolov13n.pt

# 識別結果圖輸出目錄
INFERENCE_RESULTS_ROOT=../data/results
# 預處理結果落盤
#   true  ← 保存每次檢測流程的預處理圖像
#   false ← 關閉保存，不影響主推理流程
INFERENCE_PREPROCESS_ARTIFACT_ENABLED=True
INFERENCE_PREPROCESS_ARTIFACT_ROOT=../data/results/preprocess_artifacts
INFERENCE_PREPROCESS_ARTIFACT_FAIL_ON_ERROR=False

# 資料集根目錄（訓練資料的上層目錄，詳見 data/datasets/README.md）
INFERENCE_DATASETS_ROOT=../data/datasets

# 日誌等級：DEBUG | INFO | WARNING | ERROR
INFERENCE_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Inference MCP 服務
# ─────────────────────────────────────────────────────────────
INFERENCE_MCP_LOG_LEVEL=INFO
INFERENCE_MCP_STREAMABLE_HTTP_PATH=/mcp

# ─────────────────────────────────────────────────────────────
# LLM 對話說明工具（MVP）
# 建議生產環境以系統環境變數注入 LLM_API_KEY，避免明文出現在 .env 或資料庫快照中。
# provider:
#   mock               ← 本地開發 / 測試，回傳可驗證的假資料說明
#   openai_compatible  ← 任何相容 /chat/completions 的服務
# ─────────────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=600
LLM_TIMEOUT=20

# ─────────────────────────────────────────────────────────────
# 微調訓練（Fine-Tuning）
# 以下為訓練腳本的預設值說明；實際參數建議透過 CLI 傳入：
#   ./scripts/macos/train.sh --epochs 100 --batch 8 --model yolov13s.pt
# ─────────────────────────────────────────────────────────────

# 訓練結果輸出根目錄（project 參數預設值）
# 訓練後在此目錄下建立 <name>/weights/best.pt 與 last.pt
INFERENCE_TRAIN_PROJECT=../data/train_runs

# 訓練執行名稱（name 參數預設值，用於區分不同實驗）
INFERENCE_TRAIN_NAME=rainfog_finetune

# ─────────────────────────────────────────────────────────────
# Training MCP 服務
# ─────────────────────────────────────────────────────────────
TRAINING_MCP_LOG_LEVEL=INFO
TRAINING_MCP_STREAMABLE_HTTP_PATH=/mcp
TRAINING_MCP_DJANGO_SETTINGS_MODULE=config.settings.dev
TRAINING_MCP_LOG_TAIL_LINES=100
